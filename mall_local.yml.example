server:
  http_port: 8080
  env: local
  enable_pprof: true
  log_level: debug

mysql:
  dialect: mysql
  user: root
  password: ${MYSQL_PASSWORD}
  host: 127.0.0.1
  port: 3307
  database: mall
  charset: utf8mb4
  show_sql: true
  max_open: 20
  max_idle: 5

redis:
  addr: 127.0.0.1:6379
  password: ${REDIS_PASSWORD}
  db_index: 0
  max_idle: 2
  max_open: 10

biz_conf:
  lark_group_id: ${LARK_GROUP_ID}

security:
  mobile_aes_key: ${MOBILE_AES_KEY}
  mobile_sha256_salt: ${MOBILE_SHA256_SALT}
  customer_token_ttl_sec: 604800

order:
  pay_timeout_minutes: 30
  auto_receive_days: 10
  snowflake_node_id: 1
  fee_lock_timeout_minutes: 10

wechat_pay:
  mch_id: ${WECHAT_PAY_MCH_ID}
  app_id: ${WECHAT_PAY_APP_ID}
  api_v3_key: ${WECHAT_PAY_API_V3_KEY}
  serial_no: ${WECHAT_PAY_SERIAL_NO}
  private_key_path: ${WECHAT_PAY_PRIVATE_KEY_PATH}
  payment_notify_url: ${WECHAT_PAY_PAYMENT_NOTIFY_URL}
  refund_notify_url: ${WECHAT_PAY_REFUND_NOTIFY_URL}
  native_description: "课程订单"


storage:
  secret_id: ${STORAGE_SECRET_ID}
  secret_key: ${STORAGE_SECRET_KEY}
  app_id: ${STORAGE_APP_ID}
  bucket:
    region: ${STORAGE_REGION}
    bucket_name: ${STORAGE_BUCKET_NAME}
    domain: ${STORAGE_DOMAIN}
    cdn_domain:  ${STORAGE_CDN_DOMAIN}
    paths:
      course: "/course/dev"
      lesson: "/lesson/dev"
      intro: "/intro/dev"

app_conf:
  1000:
    app_type: official
    app_name: 公众号
    app_id: ${OFFICIAL_APP_ID}
    app_secret: ${OFFICIAL_APP_SECRET}
  2000:
    app_type: lark
    app_name: 飞书
    app_id: ${LARK_APP_ID}
    app_secret: ${LARK_APP_SECRET}
